MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/surgassist
PORT=5000
CLIENT_URL=http://localhost:3000

# Parse Server
PARSE_APP_ID=surgassist
PARSE_MASTER_KEY=change_me_to_a_long_random_string
PARSE_SERVER_URL=http://localhost:5000/parse

# Parse Dashboard (optional — omit to disable)
PARSE_DASHBOARD_USER=admin
PARSE_DASHBOARD_PASSWORD=change_me
